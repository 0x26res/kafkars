{
  "name": "Partition becomes live at cutoff or end offset",
  "config": {
    "topics": [
      {
        "name": "events",
        "partitions": [
          {
            "partition": 0,
            "start_offset": 0,
            "end_offset": 2
          },
          {
            "partition": 1,
            "start_offset": 0,
            "end_offset": 100
          }
        ]
      }
    ],
    "cutoff_ms": 1000,
    "batch_size": 10
  },
  "batches": [
    {
      "description": "Partition 0 reaches end offset - becomes live but messages held by p1's low water mark (400ms)",
      "messages": [
        {
          "topic": "events",
          "partition": 0,
          "offset": 0,
          "timestamp_ms": 500
        },
        {
          "topic": "events",
          "partition": 0,
          "offset": 1,
          "timestamp_ms": 600
        },
        {
          "topic": "events",
          "partition": 1,
          "offset": 0,
          "timestamp_ms": 400
        }
      ],
      "expected_released": [
        {
          "topic": "events",
          "partition": 1,
          "offset": 0
        }
      ],
      "expected_partition_state": [
        {
          "topic": "events",
          "partition": 0,
          "consumed_offset": 1,
          "released_offset": 0,
          "is_live": true
        },
        {
          "topic": "events",
          "partition": 1,
          "consumed_offset": 0,
          "released_offset": 0,
          "is_live": false
        }
      ]
    },
    {
      "description": "Partition 1 advances to 700ms - low water mark now 700, all held messages released",
      "messages": [
        {
          "topic": "events",
          "partition": 1,
          "offset": 1,
          "timestamp_ms": 700
        }
      ],
      "expected_released": [
        {
          "topic": "events",
          "partition": 0,
          "offset": 0
        },
        {
          "topic": "events",
          "partition": 0,
          "offset": 1
        },
        {
          "topic": "events",
          "partition": 1,
          "offset": 1
        }
      ],
      "expected_partition_state": [
        {
          "topic": "events",
          "partition": 0,
          "consumed_offset": 1,
          "released_offset": 1,
          "is_live": true
        },
        {
          "topic": "events",
          "partition": 1,
          "consumed_offset": 1,
          "released_offset": 1,
          "is_live": false
        }
      ]
    },
    {
      "description": "Partition 1 reaches cutoff (1000ms) - becomes live",
      "messages": [
        {
          "topic": "events",
          "partition": 1,
          "offset": 2,
          "timestamp_ms": 1000
        }
      ],
      "expected_released": [
        {
          "topic": "events",
          "partition": 1,
          "offset": 2
        }
      ],
      "expected_partition_state": [
        {
          "topic": "events",
          "partition": 0,
          "is_live": true
        },
        {
          "topic": "events",
          "partition": 1,
          "consumed_offset": 2,
          "released_offset": 2,
          "is_live": true
        }
      ]
    }
  ]
}
