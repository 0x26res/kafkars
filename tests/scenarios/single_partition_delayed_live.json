{
  "name": "Single partition not live until message arrives",
  "data": "single_partition.json",
  "config": {
    "topics": {"events": {"partitions": [0]}},
    "cutoff_ms": 9999,
    "batch_size": 10
  },
  "batches": [
    {
      "description": "Empty poll - no messages yet, not live",
      "poll": {},
      "expected_released": [],
      "expected_partition_state": [
        {"topic": "events", "partition": 0, "is_live": false}
      ]
    },
    {
      "description": "Message arrives - partition reaches end offset and becomes live",
      "poll": {"events": {"0": [0]}},
      "expected_released": [
        {"topic": "events", "partition": 0, "offset": 0}
      ],
      "expected_partition_state": [
        {"topic": "events", "partition": 0, "consumed_offset": 0, "is_live": true}
      ]
    }
  ]
}
